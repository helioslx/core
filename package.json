{
  "name": "@helioslx/core",
  "version": "0.2.2",
  "description": "The open toolkit for modern lighting control — TypeScript sACN (E1.31) for Node.js",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "src",
    "examples",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    },
    "./redis": {
      "types": "./dist/redis.d.ts",
      "import": "./dist/redis.js"
    },
    "./http": {
      "types": "./dist/http.d.ts",
      "import": "./dist/http.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/helioslx/core.git"
  },
  "bugs": {
    "url": "https://github.com/helioslx/core/issues"
  },
  "homepage": "https://docs.helioslx.com/docs/core",
  "keywords": [
    "sacn",
    "e1.31",
    "dmx",
    "lighting",
    "udp"
  ],
  "scripts": {
    "build": "tsdown",
    "check": "npm run typecheck && npm test && npm run build && npm run test:examples",
    "test:examples": "tsc --ignoreConfig --noEmit --strict --exactOptionalPropertyTypes --noUncheckedIndexedAccess --skipLibCheck --target ES2023 --module NodeNext --moduleResolution NodeNext --types node examples/*.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run check"
  },
  "devDependencies": {
    "@elysiajs/node": "^1.4.5",
    "@elysiajs/openapi": "^1.4.15",
    "@types/node": "latest",
    "@vitest/coverage-v8": "^4.1.10",
    "elysia": "^1.4.29",
    "redis": "^6.1.0",
    "sacn": "^4.6.2",
    "tsdown": "latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "peerDependencies": {
    "@elysiajs/node": "^1.4.5",
    "@elysiajs/openapi": "^1.4.15",
    "elysia": "^1.4.29",
    "redis": "^6.1.0",
    "sacn": "^4.6.2"
  },
  "peerDependenciesMeta": {
    "@elysiajs/node": {
      "optional": true
    },
    "@elysiajs/openapi": {
      "optional": true
    },
    "elysia": {
      "optional": true
    },
    "redis": {
      "optional": true
    },
    "sacn": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0"
}
